# Copy this file to .streamlit/secrets.toml and fill in your values.
# .streamlit/secrets.toml is gitignored — never commit real credentials.

# ── Option A: Local dev (SSO via Snowflake CLI) ────────────────────────────
# Name of a connection defined in ~/.snowflake/connections.toml.
# Run `snow connection list` to see available names.
[dev]
connection_name = "premier_metrics"

# ── Option B: Cloud deployment (Streamlit Community Cloud / any server) ────
# Use a Snowflake service account with username + password (or key-pair).
# Fill this section out in the app's Secrets panel on share.streamlit.io.
# [snowflake]
# account   = "zendesk-global"          # e.g. "xy12345" or "org-account"
# user      = "svc_roster_app"
# password  = "..."
# warehouse = "REPORTING_WH"
# role      = "ROSTER_APP_ROLE"
# database  = "CLEANSED"
# schema    = "WORKDAY"
